<Window x:Class="ZeekrTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zeekr Tool"
        Height="780"
        Width="1280"
        MinHeight="720"
        MinWidth="1120"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F14">

    <!-- ZEEKR_TOOL_MARKER: MAIN_WINDOW_XAML_V5_RESPONSIVE_APPS -->

    <Window.Resources>
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Background" Value="#17212D"/>
            <Setter Property="Foreground" Value="#E7EDF5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="OrangeButton" TargetType="Button">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Background" Value="#FF6A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RedButton" TargetType="Button">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Background" Value="#7F1D1D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Background" Value="#202A36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#131A22"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#243140"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#506070"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DataGridCellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D6DEE8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#0B0F14"/>
            <Setter Property="Foreground" Value="#D6DEE8"/>
            <Setter Property="BorderBrush" Value="#243140"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#243140"/>
            <Setter Property="RowBackground" Value="#0B0F14"/>
            <Setter Property="AlternatingRowBackground" Value="#101720"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="ColumnHeaderHeight" Value="36"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#202A36"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="10,0"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#D6DEE8"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF6A2A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B2633"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF6A2A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="#101720" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                Text="Z-TOOL"
                Style="{StaticResource Text.Logo}"
                FontSize="28"
                FontWeight="Bold"
                Margin="0,14,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Button Content="Главная"
                                Style="{StaticResource SidebarButton}"
                                Background="#FF6A2A"
                                Click="ShowHome_Click"/>

                        <Button Content="Приложения"
                                Style="{StaticResource SidebarButton}"
                                Click="ShowApps_Click"/>

                        <Button Content="Установить APK"
                                Style="{StaticResource SidebarButton}"
                                Click="SelectApk_Click"/>

                        <Button Content="Запуск Activity"
                                Style="{StaticResource SidebarButton}"
                                Click="OpenActivityLauncher_Click"/>

                        <Button Content="Терминал ADB"
                                Style="{StaticResource SidebarButton}"
                                Click="OpenAdbTerminal_Click"/>

                        <Expander Header="Быстрые команды"
                                  IsExpanded="True"
                                  Foreground="White"
                                  Background="#17212D"
                                  Margin="0,18,0,0"
                                  Padding="10">
                            <StackPanel Margin="0,10,0,0">
                                <Button Content="Перезагрузить устройство" Style="{StaticResource DarkButton}" Click="Reboot_Click"/>
                                <Button Content="Сделать скриншот" Style="{StaticResource DarkButton}" Click="Screenshot_Click"/>
                                <Button Content="Очистить лог" Style="{StaticResource DarkButton}" Click="ClearLog_Click"/>
                                <Button Content="Открыть Activity Launcher" Style="{StaticResource DarkButton}" Click="OpenActivityLauncher_Click"/>
                                <Button Content="Получить список приложений" Style="{StaticResource DarkButton}" Click="LoadApps_Click"/>
                                <Button Content="Перезапустить ADB" Style="{StaticResource DarkButton}" Click="RestartAdb_Click"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>

                <TextBlock Grid.Row="2"
                           Text="v1.0.0"
                           Style="{StaticResource Text.Small}"
                           Margin="0,12,0,0"/>
            </Grid>
        </Border>

        <!-- MAIN AREA -->
        <Grid Grid.Column="1" Margin="22,18,22,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="Главная панель"
                        Style="{StaticResource Text.PageTitle}"
                        VerticalAlignment="Center"/>

                <!-- Скрытые элементы оставлены, чтобы не ломать код MainWindow.xaml.cs -->
                <StackPanel Visibility="Collapsed">
                    <TextBlock Name="TopStatusText" Text="● Ожидание"/>
                    <TextBlock Name="TopStatusSubText" Text="Устройство не подключено"/>
                </StackPanel>
            </Grid>

            <!-- DEVICE SELECTOR -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorder}"
                    Padding="10"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*" MinWidth="260"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="ADB:"
                               Style="{StaticResource Text.Value}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <ComboBox Name="DeviceComboBox"
                              Grid.Column="1"
                              Style="{StaticResource DarkComboBox}"
                              SelectionChanged="DeviceComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="Black"
                                           FontSize="14"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Grid.Column="2"
                            Content="Найти"
                            Style="{StaticResource DarkButton}"
                            Click="RefreshDevices_Click"
                            Margin="14,0,0,0"/>

                    <Button Grid.Column="3"
                            Content="Подключить"
                            Style="{StaticResource OrangeButton}"
                            Click="Connect_Click"
                            Margin="14,0,0,0"/>

                    <Button Grid.Column="4"
                            Content="Выход"
                            Style="{StaticResource RedButton}"
                            Click="Exit_Click"
                            Margin="14,0,0,0"/>
                </Grid>
            </Border>

            <!-- CONTENT AREA -->
            <Grid Grid.Row="2">
                <!-- HOME SCREEN -->
                <Grid Name="HomePanel" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- DEVICE INFO -->
                    <Border Grid.Row="0"
                            Style="{StaticResource CardBorder}"
                            Padding="22"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.45*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                <TextBlock Name="DeviceStatusText"
                                           Text="× Нет подключения"
                                           Style="{StaticResource Text.StatusError}"
                                           FontSize="20"
                                           TextWrapping="Wrap"/>
                                <TextBlock Name="DeviceSubStatusText"
                                           Text="Выбери устройство и нажми «Подключить»"
                                           Style="{StaticResource Text.BodyMuted}"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap"/>
                                <TextBlock Name="DeviceIdText"
                                           Text="ID: —"
                                           Style="{StaticResource Text.Body}"
                                           Margin="0,16,0,0"
                                           TextWrapping="Wrap"/>
                                <TextBlock Name="ConnectionTypeText"
                                           Text="Тип подключения: —"
                                           Style="{StaticResource Text.Body}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                <TextBlock Text="Имя / модель:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="DeviceModelText" Text="—" Style="{StaticResource Text.Value}" Margin="0,6,0,14" TextWrapping="Wrap"/>
                                <TextBlock Text="Бренд:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="BrandText" Text="—" Style="{StaticResource Text.Value}" Margin="0,6,0,14" TextWrapping="Wrap"/>
                                <TextBlock Text="Производитель:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="ManufacturerText" Text="—" Style="{StaticResource Text.Value}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,16,0">
                                <TextBlock Text="Android:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="AndroidVersionText" Text="—" Style="{StaticResource Text.Value}" Margin="0,6,0,14" TextWrapping="Wrap"/>
                                <TextBlock Text="SDK:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="SdkText" Text="—" Style="{StaticResource Text.Value}" Margin="0,6,0,14" TextWrapping="Wrap"/>
                                <TextBlock Text="Build:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="BuildText" Text="—" Style="{StaticResource Text.Value}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="CPU ABI:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="CpuAbiText" Text="—" Style="{StaticResource Text.Value}" Margin="0,6,0,14" TextWrapping="Wrap"/>
                                <TextBlock Text="Экран:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="ScreenText" Text="—" Style="{StaticResource Text.Value}" Margin="0,6,0,14" TextWrapping="Wrap"/>
                                <TextBlock Text="Статус:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="AdbStatusText" Text="Ожидание" Style="{StaticResource Text.Value}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- LOG + STATUS -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*" MinWidth="430"/>
                            <ColumnDefinition Width="1*" MinWidth="280"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource CardBorder}"
                                Padding="20"
                                Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <TextBlock Text="Лог действий" Style="{StaticResource Text.SectionTitle}"/>
                                    <Button Content="Очистить лог"
                                            HorizontalAlignment="Right"
                                            Width="130"
                                            Style="{StaticResource DarkButton}"
                                            Click="ClearLog_Click"
                                            Margin="0"/>
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Name="SelectedFileText"
                                           Text="APK не выбран"
                                           Style="{StaticResource Text.BodyMuted}"
                                           Margin="0,12,0,10"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBox Grid.Row="2" Name="LogBox" Style="{StaticResource Text.LogBox}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*" MinHeight="140"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Статус операции" Style="{StaticResource Text.SectionTitle}"/>

                                <Border Grid.Row="1"
                                        Background="#0B0F14"
                                        BorderBrush="#243140"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="16"
                                        Margin="0,14,0,14">
                                    <StackPanel>
                                        <TextBlock Name="OperationStatusText"
                                                   Text="✓ Готово"
                                                   Style="{StaticResource Text.StatusSuccess}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Name="OperationSubStatusText"
                                                   Text="Ожидание действий"
                                                   Style="{StaticResource Text.BodyMuted}"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"/>
                                        <ProgressBar Name="OperationProgressBar"
                                                     Height="8"
                                                     Margin="0,16,0,0"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="0"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Row="2"
                                           Text="История операций"
                                           Style="{StaticResource Text.SectionTitle}"
                                           FontSize="18"
                                           Margin="0,0,0,10"/>

                                <ListBox Grid.Row="3" Name="OperationHistoryList" Style="{StaticResource Text.OperationHistory}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- APPS SCREEN -->
                <Grid Name="AppsPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="18" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Приложения" Style="{StaticResource Text.PageTitle}" FontSize="24"/>
                                <TextBlock Text="Список пользовательских приложений выбранного устройства"
                                           Style="{StaticResource Text.BodyMuted}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="Обновить список"
                                    Style="{StaticResource OrangeButton}"
                                    Click="RefreshApps_Click"
                                    Margin="14,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="18" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Поиск:" Style="{StaticResource Text.Value}" VerticalAlignment="Center"/>
                                <TextBox Name="AppSearchBox"
                                         Grid.Column="1"
                                         MinHeight="36"
                                         Background="#0B0F14"
                                         Foreground="White"
                                         BorderBrush="#243140"
                                         Padding="10,6"
                                         TextChanged="AppSearchBox_TextChanged"/>
                            </Grid>

                            <DataGrid Name="AppsDataGrid"
                                      Grid.Row="1"
                                      Style="{StaticResource DarkDataGrid}"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      IsSynchronizedWithCurrentItem="True"
                                      SelectedCellsChanged="AppsDataGrid_SelectedCellsChanged"
                                      MouseDoubleClick="AppsDataGrid_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Package name" Binding="{Binding PackageName}" Width="2*" ElementStyle="{StaticResource DataGridCellText}"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100" ElementStyle="{StaticResource DataGridCellText}"/>
                                    <DataGridTextColumn Header="APK path" Binding="{Binding ApkPath}" Width="3*" ElementStyle="{StaticResource DataGridCellText}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="105"/>
                                <ColumnDefinition Width="115"/>
                                <ColumnDefinition Width="105"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Name="LaunchAppButton" Content="Запустить" Style="{StaticResource DarkButton}" Click="LaunchSelectedApp_Click" Margin="0,0,8,0" IsEnabled="True"/>
                            <Button Grid.Column="1" Name="StopAppButton" Content="Остановить" Style="{StaticResource DarkButton}" Click="StopSelectedApp_Click" Margin="0,0,8,0" IsEnabled="True"/>
                            <Button Grid.Column="2" Name="UninstallAppButton" Content="Удалить" Style="{StaticResource DarkButton}" Click="UninstallSelectedApp_Click" Margin="0,0,8,0" IsEnabled="True"/>
                            <Button Grid.Column="3" Name="ClearAppDataButton" Content="Очистить данные" Style="{StaticResource DarkButton}" Click="ClearSelectedAppData_Click" Margin="0,0,8,0" IsEnabled="True"/>
                            <Button Grid.Column="4" Name="BackupAppButton" Content="Выгрузить APK" Style="{StaticResource OrangeButton}" Click="BackupSelectedApp_Click" Margin="0,0,8,0" IsEnabled="True"/>
                            <Button Grid.Column="5" Name="RestoreBackupButton" Content="Установить бэкап" Style="{StaticResource DarkButton}" Click="RestoreBackupApk_Click" Margin="0,0,8,0" IsEnabled="True"/>

                            <TextBlock Grid.Column="6"
                                       Name="SelectedAppText"
                                       Text="Выбери приложение в таблице и нажми нужное действие"
                                       Style="{StaticResource Text.BodyMuted}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
