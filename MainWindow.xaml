<Window x:Class="ZeekrTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zeekr Tool"
        Height="720"
        Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F14">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВОЕ МЕНЮ -->
        <Border Grid.Column="0" Background="#101720" Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="ZEEKR X"
                               Foreground="White"
                               FontSize="34"
                               FontWeight="Bold"
                               Margin="0,20,0,35"/>

                    <Button Content="Главная" Height="46" Background="#FF6A2A" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,0,10"/>
                    <Button Content="Установить APK" Height="46" Background="#1A2430" Foreground="#C8D0DA" BorderThickness="0" Margin="0,0,0,10"/>
                    <Button Content="Приложения" Height="46" Background="#1A2430" Foreground="#C8D0DA" BorderThickness="0" Margin="0,0,0,10"/>
                    <Button Content="Запуск Activity" Height="46" Background="#1A2430" Foreground="#C8D0DA" BorderThickness="0" Margin="0,0,0,10"/>
                    <Button Content="Терминал ADB" Height="46" Background="#1A2430" Foreground="#C8D0DA" BorderThickness="0"/>
                </StackPanel>

                <Border Grid.Row="2" Background="#17212D" CornerRadius="14" Padding="16" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="● Статус ADB" Foreground="#4ADE80" FontWeight="Bold"/>
                        <TextBlock Text="Ожидание подключения" Foreground="#C8D0DA" Margin="0,10,0,0"/>
                        <TextBlock Text="USB / ADB" Foreground="#7D8793"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ОСНОВНОЙ ЭКРАН -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="160"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <DockPanel Grid.Row="0" Margin="0,0,0,22">
                <TextBlock Text="Главная панель"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           DockPanel.Dock="Left"/>

                <Button Content="Проверить ADB"
                        Click="CheckAdb_Click"
                        Width="150"
                        Height="42"
                        Background="#202A36"
                        Foreground="White"
                        BorderThickness="0"
                        DockPanel.Dock="Right"/>
            </DockPanel>

<!-- КАРТОЧКА ПОДКЛЮЧЕНИЯ -->
<Border Grid.Row="1"
        Background="#131A22"
        CornerRadius="18"
        Padding="22"
        BorderBrush="#243140"
        BorderThickness="1"
        Margin="0,0,0,20">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <TextBlock Name="DeviceStatusText"
                       Text="× Устройство не подключено"
                       Foreground="#FF6A2A"
                       FontSize="22"
                       FontWeight="Bold"/>

            <TextBlock Name="DeviceSubStatusText"
                       Text="Нажми «Проверить ADB»"
                       Foreground="#AAB4C0"
                       FontSize="14"
                       Margin="0,10,0,0"/>

            <TextBlock Name="DeviceIdText"
                       Text="ID: —"
                       Foreground="#7D8793"
                       FontSize="13"
                       Margin="0,10,0,0"/>

            <TextBlock Name="ConnectionTypeText"
                       Text="Тип подключения: —"
                       Foreground="#7D8793"
                       FontSize="13"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Column="1">
            <TextBlock Text="Имя / модель:" Foreground="#7D8793"/>
            <TextBlock Name="DeviceModelText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,6,0,12"/>

            <TextBlock Text="Бренд:" Foreground="#7D8793"/>
            <TextBlock Name="BrandText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,6,0,12"/>

            <TextBlock Text="Производитель:" Foreground="#7D8793"/>
            <TextBlock Name="ManufacturerText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,6,0,0"/>
        </StackPanel>

        <StackPanel Grid.Column="2">
            <TextBlock Text="Android:" Foreground="#7D8793"/>
            <TextBlock Name="AndroidVersionText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,6,0,12"/>

            <TextBlock Text="SDK:" Foreground="#7D8793"/>
            <TextBlock Name="SdkText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,6,0,12"/>

            <TextBlock Text="Build:" Foreground="#7D8793"/>
            <TextBlock Name="BuildText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,6,0,0"/>
        </StackPanel>

        <StackPanel Grid.Column="3">
            <TextBlock Text="CPU ABI:" Foreground="#7D8793"/>
            <TextBlock Name="CpuAbiText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,6,0,12"/>

            <TextBlock Text="Экран:" Foreground="#7D8793"/>
            <TextBlock Name="ScreenText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,6,0,12"/>

            <TextBlock Text="Статус:" Foreground="#7D8793"/>
            <TextBlock Name="AdbStatusText" Text="Ожидание" Foreground="White" FontWeight="Bold" Margin="0,6,0,0"/>
        </StackPanel>
    </Grid>
</Border>
            <!-- ДЕЙСТВИЯ -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Выбрать APK" Click="SelectApk_Click"
                        Background="#131A22" Foreground="White" FontSize="16" FontWeight="Bold"
                        BorderBrush="#243140" Margin="0,0,12,0"/>

                <Button Grid.Column="1" Content="Установить APK" Click="InstallApk_Click"
                        Background="#131A22" Foreground="White" FontSize="16" FontWeight="Bold"
                        BorderBrush="#243140" Margin="12,0,12,0"/>

                <Button Grid.Column="2" Content="Список приложений"
                        Background="#131A22" Foreground="White" FontSize="16" FontWeight="Bold"
                        BorderBrush="#243140" Margin="12,0,12,0"/>

                <Button Grid.Column="3" Content="Activity"
                        Background="#131A22" Foreground="White" FontSize="16" FontWeight="Bold"
                        BorderBrush="#243140" Margin="12,0,0,0"/>
            </Grid>

            <!-- НИЗ -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- ЛОГ -->
                <Border Grid.Column="0"
                        Background="#131A22"
                        CornerRadius="18"
                        Padding="20"
                        BorderBrush="#243140"
                        BorderThickness="1"
                        Margin="0,0,20,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Лог действий"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>

                        <TextBlock Grid.Row="1"
                                   Name="SelectedFileText"
                                   Foreground="#8E99A6"
                                   Text="APK не выбран"
                                   Margin="0,0,0,12"/>

                        <TextBox Grid.Row="2"
                                 Name="LogBox"
                                 Background="#0B0F14"
                                 Foreground="#D6DEE8"
                                 BorderBrush="#243140"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>

                <!-- БЫСТРЫЕ КОМАНДЫ -->
                <Border Grid.Column="1"
                        Background="#131A22"
                        CornerRadius="18"
                        Padding="20"
                        BorderBrush="#243140"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Быстрые команды"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,18"/>

                        <Button Content="Перезагрузить устройство" Height="42" Background="#202A36" Foreground="White" BorderThickness="0" Margin="0,0,0,10"/>
                        <Button Content="Сделать скриншот" Height="42" Background="#202A36" Foreground="White" BorderThickness="0" Margin="0,0,0,10"/>
                        <Button Content="Очистить лог" Height="42" Background="#202A36" Foreground="White" BorderThickness="0" Margin="0,0,0,10"/>
                        <Button Content="Открыть Activity Launcher" Height="42" Background="#202A36" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
