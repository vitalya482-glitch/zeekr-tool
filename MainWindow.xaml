<Window x:Class="ZeekrTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zeekr Tool"
        Height="820"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F14">

    <!-- ZEEKR_TOOL_MARKER: MAIN_WINDOW_XAML_REBUILD_V2 -->

    <Window.Resources>
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Background" Value="#17212D"/>
            <Setter Property="Foreground" Value="#E7EDF5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="OrangeButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#FF6A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#202A36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#131A22"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="#243140"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="#101720" Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="ZEEKR X"
                               Foreground="White"
                               FontSize="34"
                               FontWeight="Bold"
                               Margin="0,24,0,34"/>

                    <Button Content="Главная"
                            Style="{StaticResource SidebarButton}"
                            Background="#FF6A2A"/>

                    <Button Content="Приложения"
                            Style="{StaticResource SidebarButton}"
                            Click="LoadApps_Click"/>

                    <Button Content="Установить APK"
                            Style="{StaticResource SidebarButton}"
                            Click="SelectApk_Click"/>

                    <Button Content="Запуск Activity"
                            Style="{StaticResource SidebarButton}"
                            Click="OpenActivityLauncher_Click"/>

                    <Button Content="Терминал ADB"
                            Style="{StaticResource SidebarButton}"/>

                    <Expander Header="Быстрые команды"
                              IsExpanded="True"
                              Foreground="White"
                              Background="#17212D"
                              Margin="0,24,0,0"
                              Padding="10">
                        <StackPanel Margin="0,12,0,0">
                            <Button Content="Перезагрузить устройство"
                                    Style="{StaticResource DarkButton}"
                                    Click="Reboot_Click"/>

                            <Button Content="Сделать скриншот"
                                    Style="{StaticResource DarkButton}"
                                    Click="Screenshot_Click"/>

                            <Button Content="Очистить лог"
                                    Style="{StaticResource DarkButton}"
                                    Click="ClearLog_Click"/>

                            <Button Content="Открыть Activity Launcher"
                                    Style="{StaticResource DarkButton}"
                                    Click="OpenActivityLauncher_Click"/>

                            <Button Content="Получить список приложений"
                                    Style="{StaticResource DarkButton}"
                                    Click="LoadApps_Click"/>

                            <Button Content="Перезапустить ADB"
                                    Style="{StaticResource DarkButton}"
                                    Click="RestartAdb_Click"/>
                        </StackPanel>
                    </Expander>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="v1.0.0"
                           Foreground="#7D8793"
                           FontSize="13"
                           Margin="0,20,0,0"/>
            </Grid>
        </Border>

        <!-- MAIN AREA -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="90"/>
                <RowDefinition Height="90"/>
                <RowDefinition Height="230"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER WITH GLOBAL STATUS -->
            <Grid Grid.Row="0">
                <TextBlock Text="Главная панель"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <Border HorizontalAlignment="Right"
                        Width="380"
                        Padding="18"
                        Style="{StaticResource CardBorder}"
                        BorderBrush="#286B3A">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="95"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Name="TopStatusText"
                                       Text="● Ожидание"
                                       Foreground="#FBBF24"
                                       FontSize="18"
                                       FontWeight="Bold"/>

                            <TextBlock Name="TopStatusSubText"
                                       Text="Устройство не подключено"
                                       Foreground="#D6DEE8"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Детали"
                                Style="{StaticResource DarkButton}"
                                Height="42"
                                Margin="0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- DEVICE SELECTOR -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorder}"
                    Padding="20"
                    Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="ADB-устройство:"
                               Foreground="#AAB4C0"
                               VerticalAlignment="Center"
                               FontWeight="Bold"/>

                    <ComboBox Name="DeviceComboBox"
                              Grid.Column="1"
                              Height="40"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="DeviceComboBox_SelectionChanged"/>

                    <Button Grid.Column="2"
                            Content="Найти устройства"
                            Style="{StaticResource DarkButton}"
                            Click="RefreshDevices_Click"
                            Margin="14,0,0,0"/>

                    <Button Grid.Column="3"
                            Content="Подключить"
                            Style="{StaticResource OrangeButton}"
                            Click="Connect_Click"
                            Margin="14,0,0,0"/>
                </Grid>
            </Border>

            <!-- DEVICE INFO CARD -->
            <Border Grid.Row="2"
                    Style="{StaticResource CardBorder}"
                    Padding="24"
                    Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Name="DeviceStatusText"
                                   Text="× Устройство не подключено"
                                   Foreground="#FF6A2A"
                                   FontSize="23"
                                   FontWeight="Bold"/>

                        <TextBlock Name="DeviceSubStatusText"
                                   Text="Выбери устройство и нажми «Подключить»"
                                   Foreground="#AAB4C0"
                                   Margin="0,16,0,0"/>

                        <TextBlock Name="DeviceIdText"
                                   Text="ID: —"
                                   Foreground="#C8D0DA"
                                   Margin="0,22,0,0"/>

                        <TextBlock Name="ConnectionTypeText"
                                   Text="Тип подключения: —"
                                   Foreground="#C8D0DA"
                                   Margin="0,10,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Имя / модель:" Foreground="#7D8793"/>
                        <TextBlock Name="DeviceModelText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,8,0,18"/>

                        <TextBlock Text="Бренд:" Foreground="#7D8793"/>
                        <TextBlock Name="BrandText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,8,0,18"/>

                        <TextBlock Text="Производитель:" Foreground="#7D8793"/>
                        <TextBlock Name="ManufacturerText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Android:" Foreground="#7D8793"/>
                        <TextBlock Name="AndroidVersionText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,8,0,18"/>

                        <TextBlock Text="SDK:" Foreground="#7D8793"/>
                        <TextBlock Name="SdkText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,8,0,18"/>

                        <TextBlock Text="Build:" Foreground="#7D8793"/>
                        <TextBlock Name="BuildText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="CPU ABI:" Foreground="#7D8793"/>
                        <TextBlock Name="CpuAbiText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,8,0,18"/>

                        <TextBlock Text="Экран:" Foreground="#7D8793"/>
                        <TextBlock Name="ScreenText" Text="—" Foreground="White" FontWeight="Bold" Margin="0,8,0,18"/>

                        <TextBlock Text="Статус:" Foreground="#7D8793"/>
                        <TextBlock Name="AdbStatusText" Text="Ожидание" Foreground="White" FontWeight="Bold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- LOG + OPERATION STATUS -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardBorder}"
                        Padding="20"
                        Margin="0,0,18,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <TextBlock Text="Лог действий"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold"/>

                            <Button Content="Очистить лог"
                                    HorizontalAlignment="Right"
                                    Width="130"
                                    Style="{StaticResource DarkButton}"
                                    Click="ClearLog_Click"
                                    Margin="0"/>
                        </Grid>

                        <TextBlock Grid.Row="1"
                                   Name="SelectedFileText"
                                   Foreground="#8E99A6"
                                   Text="APK не выбран"
                                   Margin="0,16,0,12"/>

                        <TextBox Grid.Row="2"
                                 Name="LogBox"
                                 Background="#0B0F14"
                                 Foreground="#D6DEE8"
                                 BorderBrush="#243140"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource CardBorder}"
                        Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="135"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Статус операции"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"/>

                        <Border Grid.Row="1"
                                Background="#0B0F14"
                                BorderBrush="#243140"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,18,0,18">
                            <StackPanel>
                                <TextBlock Name="OperationStatusText"
                                           Text="✓ Готово"
                                           Foreground="#4ADE80"
                                           FontSize="18"
                                           FontWeight="Bold"/>

                                <TextBlock Name="OperationSubStatusText"
                                           Text="Ожидание действий"
                                           Foreground="#C8D0DA"
                                           Margin="0,10,0,0"/>

                                <ProgressBar Name="OperationProgressBar"
                                             Height="8"
                                             Margin="0,18,0,0"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Row="2"
                                   Text="История операций"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>

                        <ListBox Grid.Row="3"
                                 Name="OperationHistoryList"
                                 Background="#0B0F14"
                                 Foreground="#D6DEE8"
                                 BorderBrush="#243140"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
