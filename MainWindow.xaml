<Window x:Class="ZeekrTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zeekr Tool"
        Height="780"
        Width="1280"
        MinHeight="720"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F14">

    <!-- ZEEKR_TOOL_MARKER: MAIN_WINDOW_XAML_V5_STABLE -->

    <Window.Resources>
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#17212D"/>
            <Setter Property="Foreground" Value="#E7EDF5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="OrangeButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#FF6A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#7F1D1D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#202A36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#131A22"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#243140"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#0B0F14"/>
            <Setter Property="Foreground" Value="#D6DEE8"/>
            <Setter Property="BorderBrush" Value="#243140"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#243140"/>
            <Setter Property="RowBackground" Value="#0B0F14"/>
            <Setter Property="AlternatingRowBackground" Value="#101720"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="ColumnHeaderHeight" Value="36"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#202A36"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="10,0"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#D6DEE8"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="255"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="#101720" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="ZEEKR X"
                           Style="{StaticResource Text.Logo}"
                           FontSize="30"
                           Margin="0,24,0,28"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Button Content="Главная"
                                Style="{StaticResource SidebarButton}"
                                Background="#FF6A2A"
                                Click="ShowHome_Click"/>

                        <Button Content="Приложения"
                                Style="{StaticResource SidebarButton}"
                                Click="ShowApps_Click"/>

                        <Button Content="Установить APK"
                                Style="{StaticResource SidebarButton}"
                                Click="SelectApk_Click"/>

                        <Button Content="Запуск Activity"
                                Style="{StaticResource SidebarButton}"
                                Click="OpenActivityLauncher_Click"/>

                        <Button Content="Терминал ADB"
                                Style="{StaticResource SidebarButton}"/>

                        <Expander Header="Быстрые команды"
                                  IsExpanded="True"
                                  Foreground="White"
                                  Background="#17212D"
                                  Margin="0,20,0,0"
                                  Padding="10">
                            <StackPanel Margin="0,10,0,0">
                                <Button Content="Перезагрузить устройство"
                                        Style="{StaticResource DarkButton}"
                                        Click="Reboot_Click"/>

                                <Button Content="Сделать скриншот"
                                        Style="{StaticResource DarkButton}"
                                        Click="Screenshot_Click"/>

                                <Button Content="Очистить лог"
                                        Style="{StaticResource DarkButton}"
                                        Click="ClearLog_Click"/>

                                <Button Content="Открыть Activity Launcher"
                                        Style="{StaticResource DarkButton}"
                                        Click="OpenActivityLauncher_Click"/>

                                <Button Content="Получить список приложений"
                                        Style="{StaticResource DarkButton}"
                                        Click="LoadApps_Click"/>

                                <Button Content="Перезапустить ADB"
                                        Style="{StaticResource DarkButton}"
                                        Click="RestartAdb_Click"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>

                <TextBlock Grid.Row="2"
                           Text="v1.0.0"
                           Style="{StaticResource Text.Small}"
                           Margin="0,12,0,0"/>
            </Grid>
        </Border>

        <!-- MAIN AREA -->
        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="84"/>
                <RowDefinition Height="76"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0">
                <TextBlock Name="PageTitleText"
                           Text="Главная панель"
                           Style="{StaticResource Text.PageTitle}"
                           VerticalAlignment="Center"/>

                <Border HorizontalAlignment="Right"
                        Width="360"
                        Padding="14"
                        Style="{StaticResource CardBorder}"
                        BorderBrush="#286B3A">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="86"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Name="TopStatusText"
                                       Text="● Ожидание"
                                       Style="{StaticResource Text.TopStatus}"/>

                            <TextBlock Name="TopStatusSubText"
                                       Text="Устройство не подключено"
                                       Style="{StaticResource Text.Small}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Детали"
                                Style="{StaticResource DarkButton}"
                                Height="38"
                                Margin="0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- DEVICE SELECTOR -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorder}"
                    Padding="14"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="ADB:"
                               Style="{StaticResource Text.Value}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <ComboBox Name="DeviceComboBox"
                              Grid.Column="1"
                              Height="38"
                              Background="White"
                              Foreground="Black"
                              BorderBrush="#506070"
                              Padding="8,0"
                              VerticalContentAlignment="Center"
                              SelectionChanged="DeviceComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="Black"
                                           FontSize="14"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Grid.Column="2"
                            Content="Найти"
                            Style="{StaticResource DarkButton}"
                            Click="RefreshDevices_Click"
                            Margin="12,0,0,0"
                            Height="38"/>

                    <Button Grid.Column="3"
                            Content="Подключить"
                            Style="{StaticResource OrangeButton}"
                            Click="Connect_Click"
                            Margin="12,0,0,0"
                            Height="38"/>

                    <Button Grid.Column="4"
                            Content="Выход"
                            Style="{StaticResource DangerButton}"
                            Click="Exit_Click"
                            Margin="12,0,0,0"
                            Height="38"/>
                </Grid>
            </Border>

            <!-- CONTENT AREA -->
            <Grid Grid.Row="2">

                <!-- HOME SCREEN -->
                <Grid Name="HomePanel" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="205"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- DEVICE INFO -->
                    <Border Grid.Row="0"
                            Style="{StaticResource CardBorder}"
                            Padding="22"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.6*"/>
                                <ColumnDefinition Width="1.05*"/>
                                <ColumnDefinition Width="1.05*"/>
                                <ColumnDefinition Width="1.05*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Name="DeviceStatusText"
                                           Text="× Нет подключения"
                                           Style="{StaticResource Text.StatusError}"
                                           FontSize="20"
                                           TextWrapping="Wrap"/>

                                <TextBlock Name="DeviceSubStatusText"
                                           Text="Выбери устройство и нажми «Подключить»"
                                           Style="{StaticResource Text.BodyMuted}"
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,0"/>

                                <TextBlock Name="DeviceIdText"
                                           Text="ID: —"
                                           Style="{StaticResource Text.Body}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,18,0,0"/>

                                <TextBlock Name="ConnectionTypeText"
                                           Text="Тип подключения: —"
                                           Style="{StaticResource Text.Body}"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Имя / модель:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="DeviceModelText" Text="—" Style="{StaticResource Text.Value}" TextTrimming="CharacterEllipsis" Margin="0,6,0,14"/>
                                <TextBlock Text="Бренд:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="BrandText" Text="—" Style="{StaticResource Text.Value}" TextTrimming="CharacterEllipsis" Margin="0,6,0,14"/>
                                <TextBlock Text="Производитель:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="ManufacturerText" Text="—" Style="{StaticResource Text.Value}" TextTrimming="CharacterEllipsis" Margin="0,6,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Android:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="AndroidVersionText" Text="—" Style="{StaticResource Text.Value}" TextTrimming="CharacterEllipsis" Margin="0,6,0,14"/>
                                <TextBlock Text="SDK:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="SdkText" Text="—" Style="{StaticResource Text.Value}" TextTrimming="CharacterEllipsis" Margin="0,6,0,14"/>
                                <TextBlock Text="Build:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="BuildText" Text="—" Style="{StaticResource Text.Value}" TextTrimming="CharacterEllipsis" Margin="0,6,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="CPU ABI:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="CpuAbiText" Text="—" Style="{StaticResource Text.Value}" TextTrimming="CharacterEllipsis" Margin="0,6,0,14"/>
                                <TextBlock Text="Экран:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="ScreenText" Text="—" Style="{StaticResource Text.Value}" TextTrimming="CharacterEllipsis" Margin="0,6,0,14"/>
                                <TextBlock Text="Статус:" Style="{StaticResource Text.Label}"/>
                                <TextBlock Name="AdbStatusText" Text="Ожидание" Style="{StaticResource Text.Value}" TextTrimming="CharacterEllipsis" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- LOG + STATUS -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.25*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource CardBorder}"
                                Padding="18"
                                Margin="0,0,14,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <TextBlock Text="Лог действий"
                                               Style="{StaticResource Text.SectionTitle}"/>

                                    <Button Content="Очистить лог"
                                            HorizontalAlignment="Right"
                                            Width="130"
                                            Style="{StaticResource DarkButton}"
                                            Click="ClearLog_Click"
                                            Margin="0"/>
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Name="SelectedFileText"
                                           Text="APK не выбран"
                                           Style="{StaticResource Text.BodyMuted}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,12,0,10"/>

                                <TextBox Grid.Row="2"
                                         Name="LogBox"
                                         Style="{StaticResource Text.LogBox}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource CardBorder}"
                                Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="128"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Статус операции"
                                           Style="{StaticResource Text.SectionTitle}"/>

                                <Border Grid.Row="1"
                                        Background="#0B0F14"
                                        BorderBrush="#243140"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14"
                                        Margin="0,12,0,12">
                                    <StackPanel>
                                        <TextBlock Name="OperationStatusText"
                                                   Text="✓ Готово"
                                                   Style="{StaticResource Text.StatusSuccess}"
                                                   FontSize="18"/>

                                        <TextBlock Name="OperationSubStatusText"
                                                   Text="Ожидание действий"
                                                   Style="{StaticResource Text.BodyMuted}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,0"/>

                                        <ProgressBar Name="OperationProgressBar"
                                                     Height="8"
                                                     Margin="0,14,0,0"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="0"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Row="2"
                                           Text="История операций"
                                           Style="{StaticResource Text.SectionTitle}"
                                           FontSize="18"
                                           Margin="0,0,0,10"/>

                                <ListBox Grid.Row="3"
                                         Name="OperationHistoryList"
                                         Style="{StaticResource Text.OperationHistory}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- APPS SCREEN -->
                <Grid Name="AppsPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="98"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="54"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource CardBorder}"
                            Padding="20"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Приложения"
                                           Style="{StaticResource Text.PageTitle}"
                                           FontSize="24"/>

                                <TextBlock Text="Список пользовательских приложений выбранного устройства"
                                           Style="{StaticResource Text.BodyMuted}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="Обновить список"
                                    Style="{StaticResource OrangeButton}"
                                    Click="RefreshApps_Click"
                                    Height="42"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource CardBorder}"
                            Padding="18"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="46"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Поиск:"
                                           Style="{StaticResource Text.Value}"
                                           VerticalAlignment="Center"/>

                                <TextBox Name="AppSearchBox"
                                         Grid.Column="1"
                                         Height="34"
                                         Background="#0B0F14"
                                         Foreground="White"
                                         BorderBrush="#243140"
                                         Padding="10,6"
                                         TextChanged="AppSearchBox_TextChanged"/>
                            </Grid>

                            <DataGrid Name="AppsDataGrid"
                                      Grid.Row="1"
                                      Style="{StaticResource DarkDataGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Package name" Binding="{Binding PackageName}" Width="2*"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                                    <DataGridTextColumn Header="APK path" Binding="{Binding ApkPath}" Width="3*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Запустить"
                                Style="{StaticResource DarkButton}"
                                Click="LaunchSelectedApp_Click"
                                Margin="0,0,10,0"/>

                        <Button Grid.Column="1"
                                Content="Остановить"
                                Style="{StaticResource DarkButton}"
                                Click="StopSelectedApp_Click"
                                Margin="0,0,10,0"/>

                        <Button Grid.Column="2"
                                Content="Удалить"
                                Style="{StaticResource DarkButton}"
                                Click="UninstallSelectedApp_Click"
                                Margin="0,0,10,0"/>

                        <Button Grid.Column="3"
                                Content="Очистить данные"
                                Style="{StaticResource DarkButton}"
                                Click="ClearSelectedAppData_Click"
                                Margin="0,0,10,0"/>

                        <TextBlock Grid.Column="4"
                                   Text="Выбери приложение в таблице и нажми нужное действие"
                                   Style="{StaticResource Text.BodyMuted}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
