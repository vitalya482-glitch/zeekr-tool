<Window x:Class="ZeekrTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zeekr Tool"
        Height="400"
        Width="600"
        Background="#0B0F14">

    <Grid>
        <StackPanel Margin="20">

            <TextBlock Text="Zeekr Tool"
                       Foreground="White"
                       FontSize="24"
                       Margin="0,0,0,20"/>

            <Button Content="Проверить ADB"
                    Click="CheckAdb_Click"
                    Height="40"
                    Margin="0,0,0,10"/>

            <TextBox Name="LogBox"
                     Height="200"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>

        </StackPanel>
    </Grid>

</Window>
